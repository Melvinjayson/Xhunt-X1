# ─────────────────────────────────────────────────────────────────────────────
# X-Hunt Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Auth — PREVIEW BUILD (Clerk removed 2026-06-13) ──────────────────────────
# Clerk was removed for the preview build. All routes are open.
# API routes use clerkId = 'preview-user' stub.
# When reinstating auth, restore files listed in memory/project_clerk_removal.md.
# Add these back only when auth is reinstated:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
# CLERK_WEBHOOK_SECRET=whsec_...

# ── AI Providers ──────────────────────────────────────────────────────────────
# Groq — consumer AI, onboarding (Xeno), mission generation
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Anthropic Claude — XIL Orchestrator + all 14 specialist agents
# REQUIRED for: Mission Architect, Fraud Prevention, Reward Economist,
#   Trust Guardian, all compound intelligence routes
# https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# LLM routing (optional — defaults to 'groq' for consumer, 'anthropic' for XIL)
LLM_PROVIDER=groq

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook → https://your-domain.com/api/stripe/webhook
# Events: customer.subscription.created, customer.subscription.deleted,
#         invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://xhunt.app

# ── Cron security ─────────────────────────────────────────────────────────────
# Protects /api/cron/* endpoints. Generate: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
# 1. Set all variables above in your platform (Vercel → Settings → Env Vars)
# 2. Run Supabase migrations in order:
#      supabase db push
#    Or apply individually: supabase/migrations/001_initial.sql → 030_verification_layer.sql
# 3. Verify RLS is enabled on all tables (migrations enable it per-table)
# 4. Configure Stripe webhook endpoint in Stripe Dashboard
# 5. Set ANTHROPIC_API_KEY to enable XIL intelligence agents
# 6. Set GROQ_API_KEY to enable consumer AI (Xeno onboarding, recommendations)
# 7. Confirm CRON_SECRET matches the value set in your cron scheduler
# 8. Preview build: CLERK vars are OPTIONAL — all routes are open
#    Production auth: restore Clerk per memory/project_clerk_removal.md
# ─────────────────────────────────────────────────────────────────────────────
